// Local.xcconfig.example
// ========================
// Template for local development configuration
// Copy this file to Local.xcconfig and customize as needed
// Local.xcconfig is gitignored and will NOT be committed
//
// Usage:
// 1. Copy: cp Config/Local.xcconfig.example Config/Local.xcconfig
// 2. Edit Local.xcconfig with your settings
// 3. Create a User Scheme in Xcode (see README below)
//
// ========================

// Development Bundle Identifier (must differ from dev.quotio.desktop)
// Any non-production bundle id automatically switches RuntimeProfile to:
// - UserDefaults domain: <bundle id>
// - Application Support: ~/Library/Application Support/Quotio-<suffix>
// - Auth directory: ~/.cli-proxy-api-<suffix>
// - Keychain services: <bundle id>.*
// - Default proxy port: 18317 (internal CLIProxyAPI becomes 28317)
PRODUCT_BUNDLE_IDENTIFIER = dev.quotio.desktop.dev

// Development App Name (to distinguish in Dock/Finder)
PRODUCT_NAME = Quotio Dev

// Display name shown under app icon
INFOPLIST_KEY_CFBundleDisplayName = Quotio Dev

// Development App Icon (uses AppIconDev instead of AppIcon)
ASSETCATALOG_COMPILER_APPICON_NAME = AppIconDev

// ========================
// CREATING USER SCHEME IN XCODE:
// ========================
// 1. Open Quotio.xcodeproj in Xcode
// 2. Click on scheme selector (top left, next to Stop button)
// 3. Click "Manage Schemes..."
// 4. Select "Quotio" scheme → Click "Duplicate" (or press Cmd+D)
// 5. Rename to "Quotio Dev"
// 6. IMPORTANT: Uncheck "Shared" checkbox (this makes it user-only, not tracked by git)
// 7. Click "Close"
//
// Now use "Quotio Dev" scheme for development!
// The production "Quotio" scheme remains unchanged.
// ========================

// Optional: You can also override other settings here
// CODE_SIGN_IDENTITY = -
// DEVELOPMENT_TEAM = 
